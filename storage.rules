rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'nitinjain@jainbafna.com';
    }

    // Applicants can upload resumes, but cannot read/delete.
    // Admin can read/delete all resumes.
    match /resumes/{userId}/{fileName} {
      allow write: if true;
      allow read, delete: if isAdmin();
    }

    // Default-deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
